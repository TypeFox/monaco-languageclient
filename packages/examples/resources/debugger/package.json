{
  "name": "graalpy-debugger",
  "version": "2026.6.1",
  "description": "Monaco Language client Graalpy Debugger",
  "license": "MIT",
  "author": {
    "name": "TypeFox GmbH",
    "url": "http://www.typefox.io"
  },
  "type": "module",
  "main": "./dist/debugServer.js",
  "module": "./dist/debugServer.js",
  "typesVersions": {
    "*": {
      ".": [
        "dist/debugServer"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/debugServer.d.ts",
      "import": "./dist/debugServer.js",
      "default": "./dist/debugServer.js"
    }
  },
  "scripts": {
    "start": "npm i && tsx src/debugServer.ts"
  },
  "dependencies": {
    "express": "~5.2.1",
    "monaco-languageclient": "~11.0.0-next.0",
    "ws": "~8.21.0"
  },
  "devDependencies": {
    "tsx": "~4.22.4"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  }
}
