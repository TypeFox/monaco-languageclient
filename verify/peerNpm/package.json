{
  "name": "@typefox/peer-check-npm",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "verify": "npm ci && npm run build && npm run start",
    "verify:ci": "npm ci && npm run build",
    "clean": "shx rm -fr dist",
    "build:msg": "echo Building client-vite example:",
    "build:tsc": "tsc --build tsconfig.json",
    "build": "npm run build:msg && npm run clean && npm run build:tsc && npm run vite:build",
    "dev": "vite",
    "dev:debug": "vite --debug --force",
    "vite:build": "vite build",
    "start": "vite preview"
  },
  "dependencies": {
    "monaco-languageclient-examples": "../../packages/examples",
    "vscode": "npm:@codingame/monaco-vscode-extension-api@^34.1.1"
  },
  "devDependencies": {
    "shx": "~0.4.0",
    "typescript": "~6.0.3",
    "vite": "~8.0.16"
  },
  "overrides": {
    "@typefox/monaco-editor-react": "../../packages/wrapper-react",
    "monaco-languageclient": "../../packages/client",
    "monaco-languageclient-examples": "../../packages/examples",
    "vscode-ws-jsonrpc": "../../packages/vscode-ws-jsonrpc"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  }
}
