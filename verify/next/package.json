{
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.10.0",
    "npm": ">=10.2.3"
  },
  "scripts": {
    "clean": "shx rm -fr .next dist lib bundle *.tsbuildinfo",
    "verify": "npm install && npm run dev",
    "verify:ci": "npm install && npm run build -d",
    "dev": "npm run bundle && npm run build:tsc && npm run dev:next",
    "dev:next": "next dev -p 8083",
    "dev:vite": "vite --config vite.config.ts",
    "build": "npm run build:tsc && npm run bundle --workspace editor && next build",
    "bundle": "vite --config vite.config.bundle.ts build",
    "build:tsc": "tsgo --build ",
    "watch:tsc": "tsgo --build --watch",
    "start": "next start"
  },
  "dependencies": {
    "@codingame/monaco-vscode-api": "^24.2.0",
    "@codingame/monaco-vscode-keybindings-service-override": "^24.2.0",
    "@codingame/monaco-vscode-typescript-language-features-default-extension": "^24.2.0",
    "@typefox/monaco-editor-react": "~7.5.0",
    "langium": "~4.1.3",
    "monaco-languageclient": "~10.5.0",
    "next": "~16.1.1",
    "react": "~19.2.3",
    "react-dom": "~19.2.3",
    "vscode": "npm:@codingame/monaco-vscode-extension-api@^24.2.0",
    "vscode-languageclient": "~9.0.1",
    "vscode-languageserver": "~9.0.1"
  },
  "devDependencies": {
    "@codingame/esbuild-import-meta-url-plugin": "~1.0.3",
    "@typescript/native-preview": "~7.0.0-dev.20251223.1",
    "@types/node": "~22.15.35",
    "@types/react": "~19.2.7",
    "@types/react-dom": "~19.2.3",
    "shx": "~0.4.0",
    "vite": "~8.0.0-beta.4"
  },
  "volta": {
    "node": "22.20.0",
    "npm": "10.9.3"
  }
}
