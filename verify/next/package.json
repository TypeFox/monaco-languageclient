{
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "shx rm -fr .next dist lib bundle *.tsbuildinfo",
    "verify": "npm install && npm run dev",
    "verify:ci": "npm install && npm run build -d",
    "dev:next": "npm run bundle && npm run build:tsc && next dev -p 8083",
    "dev:vite": "npm run bundle && npm run build:tsc && vite --config vite.config.ts",
    "build": "npm run bundle && next build",
    "bundle": "npm run bundle:config && npm run bundle:editorWorker && npm run bundle:textmateWorker",
    "bundle:config": "vite --config vite.config.bundle.ts build",
    "bundle:editorWorker": "vite --config vite.config.editorWorker.ts build",
    "bundle:extHostWorker": "vite --config vite.config.extHostWorker.ts build",
    "bundle:extensionService": "vite --config vite.config.extensionService.ts build",
    "bundle:textmateWorker": "vite --config vite.config.textmateWorker.ts build",
    "bundle:tsserver": "vite --config vite.config.tsserver.ts build",
    "build:tsc": "tsgo --build ",
    "watch:tsc": "tsgo --build --watch",
    "start": "next start"
  },
  "dependencies": {
    "@codingame/monaco-vscode-api": "^33.0.9",
    "@codingame/monaco-vscode-editor-api": "^33.0.9",
    "@codingame/monaco-vscode-extensions-service-override": "^33.0.9",
    "@codingame/monaco-vscode-keybindings-service-override": "^33.0.9",
    "@codingame/monaco-vscode-textmate-service-override": "^33.0.9",
    "@codingame/monaco-vscode-typescript-basics-default-extension": "^33.0.9",
    "@codingame/monaco-vscode-typescript-language-features-default-extension": "^33.0.9",
    "@codingame/monaco-vscode-views-service-override": "^33.0.9",
    "@typefox/monaco-editor-react": "~8.0.0-next.0",
    "langium": "~4.3.0",
    "monaco-languageclient": "~11.0.0-next.0",
    "next": "~16.2.9",
    "react": "~19.2.7",
    "react-dom": "~19.2.7",
    "vscode": "npm:@codingame/monaco-vscode-extension-api@^33.0.9",
    "vscode-languageclient": "~10.0.0",
    "vscode-languageserver": "~10.0.0"
  },
  "devDependencies": {
    "@types/react-dom": "~19.2.3",
    "@typescript/native-preview": "beta",
    "shx": "~0.4.0",
    "vite": "~8.0.0-beta.14"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  }
}
