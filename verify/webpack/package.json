{
  "name": "example-client-webpack",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "verify": "npm ci && npm run build && npm run start",
    "verify:ci": "npm ci && npm run build",
    "clean": "shx rm -fr bundle dist public *.tsbuildinfo",
    "build:msg": "echo Building client-webpack example:",
    "build": "npm run build:msg && npm run clean && npm run bundle && webpack",
    "start": "http-server ./ --port 8082",
    "bundle": "npm run bundle:editorWorker && npm run bundle:textmateWorker",
    "bundle:editorWorker": "vite --config vite.config.editorWorker.ts build",
    "bundle:textmateWorker": "vite --config vite.config.textmateWorker.ts build"
  },
  "dependencies": {
    "@codingame/monaco-vscode-textmate-service-override": "^34.1.1",
    "monaco-languageclient-examples": "../../packages/examples"
  },
  "devDependencies": {
    "css-loader": "~7.1.4",
    "http-server": "~14.1.1",
    "shx": "~0.4.0",
    "source-map-loader": "~5.0.0",
    "style-loader": "~4.0.0",
    "ts-loader": "~9.6.1",
    "vite": "~8.0.16",
    "webpack-cli": "~7.0.3"
  },
  "overrides": {
    "@typefox/monaco-editor-react": "../../packages/wrapper-react",
    "monaco-languageclient": "../../packages/client",
    "monaco-languageclient-examples": "../../packages/examples",
    "vscode-ws-jsonrpc": "../../packages/vscode-ws-jsonrpc"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  }
}
